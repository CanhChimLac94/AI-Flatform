# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://omni:omni_secret@localhost:5432/omni_ai
REDIS_URL=redis://localhost:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_random_secret_256_bits
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── LLM Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GOOGLE_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...
NVIDIA_API_KEY=nvapi-...

# ─── Vector DB ───────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=omni-memories
# Set USE_PGVECTOR=true to use local pgvector instead of Pinecone
USE_PGVECTOR=true

# ─── Search Tool ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
ENVIRONMENT=development


GOOGLE_API_KEY=<your-google-api-key>
GOOGLE_CSE_ID=<your-custom-search-engine-id>
